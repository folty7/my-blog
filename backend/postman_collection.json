						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"My First Post\",\n    \"slug\": \"moj-prvy-post\",\n    \"content\": \"This is my test content.\",\n    \"tags\": [\"coding\", \"blog\"]\n}"
						},
						"url": {
							"raw": "{{base_url}}/posts",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"posts"
