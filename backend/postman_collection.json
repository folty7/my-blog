						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"My Updated Title\",\n    \"tags\": [\"coding\", \"updated\"]\n}"
						},
						"url": {
							"raw": "{{base_url}}/posts/1",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"posts",
								"1"
							]
						}
					}
				},
				{
					"name": "5. Delete Post",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
